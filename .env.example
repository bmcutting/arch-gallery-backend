# Database (Supabase / PostgreSQL connection string)
# Special characters in the password MUST be URL-encoded (e.g. $ -> %24, @ -> %40)
DATABASE_URL=postgresql://user:password@host:5432/database

TOKEN_SECRET_WORD=your_access_token_secret
REFRESH_SECRET_WORD=your_refresh_token_secret

PORT=3000
NODE_ENV=local
